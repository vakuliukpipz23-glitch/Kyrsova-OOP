@model Kyrsova_OOP.Models.Habit

<h2>Історія виконання звички</h2>

<p><b>@Model.Title</b></p>

<p><b>Дата створення:</b> @Model.CreatedDate.ToShortDateString()</p>

<h3>Історія по днях</h3>

<ul>

@{
    var start = Model.CreatedDate.Date;
    var end = DateTime.Today.Date;
}

@for (var day = start; day <= end; day = day.AddDays(1))
{
    bool done = Model.Records.Any(r => r.Date.Date == day);

    if (done)
    {
        <li>@day.ToShortDateString() — виконано</li>
    }
    else
    {
        <li>@day.ToShortDateString() — пропущено</li>
    }
}

</ul>

<a href="/Habit">Назад</a>