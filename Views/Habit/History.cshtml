@model Kyrsova_OOP.Models.Habit

@{
  ViewData["Title"] = "History - " + (Model?.Name ?? "Habit");
}

<div class="dashboard">
  <div class="card">
    <h2 class="card-title">Історія виконання звички</h2>
    <p><strong>@Model.Name</strong></p>
    <p><strong>Дата створення:</strong> @Model.CreatedDate.ToShortDateString()</p>

    <h3>Історія по днях</h3>
    <ul class="list-group">
    @{
        var start = Model.CreatedDate.Date;
        var end = DateTime.Today.Date;
    }

    @for (var day = start; day <= end; day = day.AddDays(1))
    {
        bool done = Model.Records.Any(r => r.Date.Date == day);
        if (done)
        {
            <li class="list-group-item">@day.ToShortDateString() — виконано</li>
        }
        else
        {
            <li class="list-group-item">@day.ToShortDateString() — пропущено</li>
        }
    }
    </ul>

    <div style="margin-top:16px">
      <a class="btn btn-secondary" asp-controller="Habit" asp-action="Index">Назад</a>
    </div>
  </div>
</div>