@model Kyrsova_OOP.Models.Habit

@{
		ViewData["Title"] = "Edit Habit";
}

<div class="dashboard">
	<div class="card">
		<h2 class="card-title">Edit Habit</h2>
		@if (ViewBag.Error != null)
		{
			<p class="text-danger">@ViewBag.Error</p>
		}
		<form method="post">
			<input type="hidden" name="id" value="@Model.Id" />

			<label class="muted">Name</label>
			<input class="form-control" type="text" name="name" value="@Model.Name" />

			<div style="margin-top:16px">
				<button class="btn" type="submit">Save</button>
				<a class="btn btn-secondary" asp-controller="Habit" asp-action="Index">Back</a>
			</div>
		</form>
	</div>
</div>