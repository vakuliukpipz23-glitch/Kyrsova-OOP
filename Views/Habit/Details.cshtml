@model Kyrsova_OOP.Models.Habit

@{
		ViewData["Title"] = Model?.Title ?? "Habit Details";
}

<div class="dashboard">
	<div class="card">
		<h2 class="card-title">@Model.Title</h2>
		<p class="habit-meta">Created: @Model.CreatedDate.ToShortDateString()</p>

		<ul class="stats-list">
			<li><strong>Current streak:</strong> @ViewBag.CurrentStreak</li>
			<li><strong>Longest streak:</strong> @ViewBag.LongestStreak</li>
			<li><strong>Total completions:</strong> @ViewBag.Total</li>
		</ul>

		<div style="margin-top:16px">
			<a class="btn btn-secondary" asp-controller="Habit" asp-action="Index">Back</a>
		</div>
	</div>
</div>