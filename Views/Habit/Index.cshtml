@model List<Kyrsova_OOP.Models.Habit>

<h1>Трекер звичок</h1>

<a href="/Habit/Add">Додати звичку</a> |
<a href="/Habit/Statistics">Статистика</a>

<table border="1">

<tr>
<th>Звичка</th>
<th>Створено</th>
<th>Завершено сьогодні</th>
<th>Поточна серія</th>
<th>Найдовша серія</th>
<th>Всього</th>
<th>Оцінити</th>
<th>Дії</th>
</tr>

@foreach (var habit in Model)
{
<tr>

<td>@habit.Title</td>

<td>@habit.CreatedDate.ToShortDateString()</td>

<td>
@(habit.IsCompletedToday() ? "Завершено" : "Ні")
</td>

<td>@habit.GetCurrentStreak()</td>

<td>@habit.GetLongestStreak()</td>

<td>@habit.GetTotalCompletions()</td>

<td>@habit.GetCompletionRate().ToString("0.0") %</td>

<td>

<a href="/Habit/Complete/@habit.Id">Завершити</a> |

<a href="/Habit/Details/@habit.Id">Деталі</a> |

<a href="/Habit/History/@habit.Id">Історія</a> |

<a href="/Habit/Edit/@habit.Id">Редагувати</a> |

<a href="/Habit/Delete/@habit.Id">Видалити</a>

</td>

</tr>
}

</table>