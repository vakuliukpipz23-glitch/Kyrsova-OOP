@model List<Kyrsova_OOP.Models.Habit>

<h2>Global Statistics</h2>

<p>Total habits: @ViewBag.TotalHabits</p>
<p>Total completions: @ViewBag.TotalCompletions</p>
<p>Best streak: @ViewBag.BestStreak</p>

<hr />

<a href="/Habit/Add">Add Habit</a>

<br /><br />

<h1>Habit Tracker</h1>

<table border="1" cellpadding="10">
<tr>
<th>Habit</th>
<th>Completed Today</th>
<th>Current Streak</th>
<th>Longest Streak</th>
<th>Total</th>
<th>Rate</th>
<th>Actions</th>
</tr>

@foreach (var habit in Model)
{
<tr>
<td>@habit.Title</td>
<td>
@if (habit.IsCompletedToday())
{
    <span style="color:green;">Completed</span>
}
else
{
    <span style="color:gray;">Not completed</span>
}
</td>
<td>@habit.GetCurrentStreak()</td>
<td>@habit.GetLongestStreak()</td>
<td>@habit.GetTotalCompletions()</td>
<td>@habit.GetCompletionRate().ToString("0.0") %</td>
<td>
<a href="/Habit/Complete/@habit.Id">Complete</a> |
<a href="/Habit/Details/@habit.Id">Details</a> |
<a href="/Habit/History/@habit.Id">History</a> |
<a href="/Habit/Delete/@habit.Id">Delete</a>
</td>
</tr>
}

</table>