@model List<Kyrsova_OOP.Models.Habit>

<h1>Глобальна статистика</h1>

<p><b>Всього звичок:</b> @ViewBag.TotalHabits</p>
<p><b>Всього виконань:</b> @ViewBag.TotalCompletions</p>
<p><b>Найкраща серія:</b> @ViewBag.BestStreak</p>

<hr />

<h2>Статистика по кожній звичці</h2>

@foreach (var habit in Model)
{
    int totalDays = (DateTime.Today - habit.CreatedDate).Days + 1;
    int completed = habit.GetTotalCompletions();
    int missed = totalDays - completed;

    <h3>@habit.Title</h3>

    <p><b>Дата створення:</b> @habit.CreatedDate.ToShortDateString()</p>

    <ul>
        <li>Виконано днів: @completed</li>
        <li>Пропущено днів: @missed</li>
        <li>Поточна серія: @habit.GetCurrentStreak()</li>
        <li>Найдовша серія: @habit.GetLongestStreak()</li>
        <li>Успішність: @habit.GetCompletionRate().ToString("0.0") %</li>
    </ul>

    <hr />
}

<a href="/Habit">Назад</a>