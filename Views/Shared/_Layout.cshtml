<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Habit App</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="app">
    <header class="app-header">
        <div class="app-header__brand">
            <a class="app-logo" asp-area="" asp-controller="Home" asp-action="Index">Habit App</a>
            <nav class="app-nav">
                <a class="app-nav__link" asp-controller="Habit" asp-action="Index">Habits</a>
            </nav>
        </div>
    </header>

    <main class="app-main">
        <div class="app-container">
            @RenderBody()
        </div>
    </main>

    <footer class="app-footer">
        <div class="app-container">
            <span>&copy; @DateTime.Now.Year Habit App</span>
            <span class="app-footer__spacer"></span>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
